# ==============================================================
#  RST.Inventar – Umgebungsvariablen (Vorlage)
#  Kopiere diese Datei nach .env und trage deine Werte ein.
#  .env wird NICHT ins Git eingecheckt!
# ==============================================================

# ── MariaDB ───────────────────────────────────────────────────
MARIADB_PORT=3306
MARIADB_ROOT_PASSWORD=change_me_root
MARIADB_DATABASE=rst_inventar
MARIADB_USER=rst_user
MARIADB_PASSWORD=change_me_app

# ── Keycloak Datenbank (läuft in derselben MariaDB) ───────────
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change_me_kc_db

# ── Keycloak Admin ────────────────────────────────────────────
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_kc_admin

# ── phpMyAdmin ────────────────────────────────────────────────
PHPMYADMIN_PORT=8080

# ── RustFS (S3-kompatibler Objektspeicher) ────────────────────
RUSTFS_PORT_API=9000
RUSTFS_PORT_CONSOLE=9001
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=change_me_rustfs_secret

# ── App (PHP/Apache) ──────────────────────────────────────────
APP_PORT=80
